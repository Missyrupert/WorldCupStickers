# Copy this file to .env.local — never commit .env.local to git.

# OpenAI — image transformation via gpt-image-1 (Stage 1)
# Get your key at: https://platform.openai.com/api-keys
# Cost: ~$0.04/image at medium quality. Monitor at: https://platform.openai.com/usage
OPENAI_API_KEY=

# Anthropic — player name generation via Claude (Stage 2)
# Get your key at: https://console.anthropic.com/settings/keys
# Cost: ~$0.00025 per name (negligible)
ANTHROPIC_API_KEY=

# Replicate — alternative image engine (swap in route.ts when you have credits)
# Get your token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
