# Copy this file to .env.local in the project root (same folder as package.json).

# Anthropic API key — used for Stage 2 (player name generation via Claude)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI API key — used for Stage 1 (image transformation via gpt-image-1)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
